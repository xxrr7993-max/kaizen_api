{
  "info": {
    "name": "kaizen_api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "victoryId", "value": "" },
    { "key": "discardableId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.refreshToken);",
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has accessToken', () => pm.expect(json.accessToken).to.be.a('string'));",
              "pm.test('Has user.id', () => pm.expect(json.user.id).to.be.a('string'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Rodger Dias\",\n  \"email\": \"rodger@kaizen.com\",\n  \"password\": \"senha123\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.refreshToken);",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has tokens', () => { pm.expect(json.accessToken).to.be.a('string'); pm.expect(json.refreshToken).to.be.a('string'); });"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rodger@kaizen.com\",\n  \"password\": \"senha123\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.refreshToken);",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('New tokens returned', () => pm.expect(json.accessToken).to.be.a('string'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rodger@kaizen.com\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/change-password",
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"senha123\",\n  \"newPassword\": \"senha123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Users",
      "item": [
        {
          "name": "Get Profile (me)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has name and email', () => { pm.expect(json.name).to.be.a('string'); pm.expect(json.email).to.be.a('string'); });",
              "pm.test('Has streak fields', () => { pm.expect(json.streak).to.be.a('number'); pm.expect(json.record).to.be.a('number'); });"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update Profile (me)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Name updated', () => pm.expect(pm.response.json().name).to.eql('Rodger Atualizado'));"
            ]}
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/me",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Rodger Atualizado\"\n}" }
          }
        }
      ]
    },
    {
      "name": "3. Victories — Setup",
      "item": [
        {
          "name": "Onboarding — Save All (PUT)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('4 victories returned', () => pm.expect(json).to.have.length(4));",
              "pm.collectionVariables.set('victoryId', json[0].id);",
              "pm.test('First victory is FISICA', () => pm.expect(json[0].category).to.eql('fisica'));",
              "pm.test('Victory has subtasks', () => pm.expect(json[0].subtasks).to.be.an('array'));"
            ]}
          }],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/victories",
            "body": { "mode": "raw", "raw": "[\n  {\"category\": \"FISICA\", \"goal\": \"Malhar 30 min\", \"subtasks\": [\"Aquecimento\", \"Treino força\"]},\n  {\"category\": \"MENTAL\", \"goal\": \"Ler 20 páginas\", \"subtasks\": []},\n  {\"category\": \"ESPIRITUAL\", \"goal\": \"Meditar 10 min\", \"subtasks\": []},\n  {\"category\": \"PESSOAL\", \"goal\": \"Estudar inglês\", \"subtasks\": [\"Duolingo\"]}\n]" }
          }
        },
        {
          "name": "List All Victories",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/victories"
          }
        }
      ]
    },
    {
      "name": "4. Checkin",
      "item": [
        {
          "name": "Get Today",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has date', () => pm.expect(json.date).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
              "pm.test('Has 4 victories', () => pm.expect(json.victories).to.have.length(4));",
              "pm.test('completedCount is 0', () => pm.expect(json.completedCount).to.eql(0));",
              "pm.collectionVariables.set('victoryId', json.victories[0].victoryId);"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/today"
          }
        },
        {
          "name": "Toggle Victory",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('completedCount is 1', () => pm.expect(json.completedCount).to.eql(1));",
              "var v = json.victories.find(v => v.victoryId === pm.collectionVariables.get('victoryId'));",
              "pm.test('Victory is completed', () => pm.expect(v.completed).to.be.true);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/victory/{{victoryId}}/toggle"
          }
        },
        {
          "name": "Toggle Victory (undo)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('completedCount back to 0', () => pm.expect(pm.response.json().completedCount).to.eql(0));"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/victory/{{victoryId}}/toggle"
          }
        },
        {
          "name": "Toggle Subtask (index 0)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "var v = pm.response.json().victories.find(v => v.victoryId === pm.collectionVariables.get('victoryId'));",
              "pm.test('Subtask 0 is completed', () => pm.expect(v.subtasks[0].completed).to.be.true);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/victory/{{victoryId}}/subtask/0/toggle"
          }
        },
        {
          "name": "Toggle Subtask (undo)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "var v = pm.response.json().victories.find(v => v.victoryId === pm.collectionVariables.get('victoryId'));",
              "pm.test('Subtask 0 back to false', () => pm.expect(v.subtasks[0].completed).to.be.false);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/victory/{{victoryId}}/subtask/0/toggle"
          }
        },
        {
          "name": "Get Streak",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has current and record', () => { pm.expect(json.current).to.be.a('number'); pm.expect(json.record).to.be.a('number'); });"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/streak"
          }
        },
        {
          "name": "Get Weekly",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('7 days returned', () => pm.expect(json).to.have.length(7));",
              "pm.test('Days have victories map', () => { pm.expect(json[0].victories).to.have.all.keys('fisica','mental','espiritual','pessoal'); });"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/week"
          }
        },
        {
          "name": "Get Monthly",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has month field', () => pm.expect(json.month).to.be.a('string'));",
              "pm.test('Has days map', () => pm.expect(json.days).to.be.an('object'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/checkin/month?m=2026-06", "query": [{ "key": "m", "value": "2026-06" }] }
          }
        },
        {
          "name": "Add Discardable Task",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Discardable added', () => pm.expect(json.discardable).to.have.length(1));",
              "pm.collectionVariables.set('discardableId', json.discardable[0].id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/checkin/discardable",
            "body": { "mode": "raw", "raw": "{\n  \"goal\": \"Beber 2L de água\"\n}" }
          }
        },
        {
          "name": "Toggle Discardable Task",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "var d = pm.response.json().discardable.find(t => t.id === pm.collectionVariables.get('discardableId'));",
              "pm.test('Task is completed', () => pm.expect(d.completed).to.be.true);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/discardable/{{discardableId}}/toggle"
          }
        },
        {
          "name": "Delete Discardable Task",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Discardable removed', () => pm.expect(pm.response.json().discardable).to.have.length(0));"
            ]}
          }],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/discardable/{{discardableId}}"
          }
        }
      ]
    },
    {
      "name": "5. Stats",
      "item": [
        {
          "name": "Progress Stats (6 months)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('6 months returned', () => pm.expect(json.months).to.have.length(6));",
              "pm.test('Has current stats', () => { pm.expect(json.current.streak).to.be.a('number'); pm.expect(json.current.record).to.be.a('number'); });",
              "pm.test('Has completion map', () => { pm.expect(json.completion).to.have.all.keys('fisica','mental','espiritual','pessoal'); });"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/stats/monthly?months=6", "query": [{ "key": "months", "value": "6" }] }
          }
        },
        {
          "name": "Heatmap (28 days)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('28 days returned', () => pm.expect(json.days).to.have.length(28));",
              "pm.test('Days have victories map', () => { pm.expect(json.days[0].victories).to.have.all.keys('fisica','mental','espiritual','pessoal'); });"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/stats/heatmap"
          }
        }
      ]
    },
    {
      "name": "6. Victories — CRUD extra",
      "item": [
        {
          "name": "Create Single Victory",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Victory created', () => pm.expect(json.id).to.be.a('string'));",
              "pm.collectionVariables.set('victoryId', json.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/victories",
            "body": { "mode": "raw", "raw": "{\n  \"category\": \"FISICA\",\n  \"goal\": \"Nadar 1km\",\n  \"subtasks\": [\"Aquecimento\", \"Nado livre\"]\n}" }
          }
        },
        {
          "name": "Update Victory",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Goal updated', () => pm.expect(pm.response.json().goal).to.eql('Nadar 2km'));"
            ]}
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/victories/{{victoryId}}",
            "body": { "mode": "raw", "raw": "{\n  \"category\": \"FISICA\",\n  \"goal\": \"Nadar 2km\",\n  \"subtasks\": [\"Aquecimento\", \"Nado livre\", \"Alongamento\"]\n}" }
          }
        },
        {
          "name": "Delete Single Victory",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] }
          }],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/victories/{{victoryId}}"
          }
        },
        {
          "name": "Reset All Victories",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] }
          }],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/victories"
          }
        }
      ]
    }
  ]
}
