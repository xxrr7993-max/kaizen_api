{
  "info": {
    "name": "kaizen_api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "victoryId", "value": "" },
    { "key": "discardableId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has accessToken', () => pm.expect(json.accessToken).to.be.a('string'));",
                  "pm.test('Has user.id', () => pm.expect(json.user.id).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rodger Dias\",\n  \"email\": \"rodger@kaizen.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has tokens', () => { pm.expect(json.accessToken).to.be.a('string'); pm.expect(json.refreshToken).to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rodger@kaizen.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('New tokens returned', () => { pm.expect(json.accessToken).to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rodger@kaizen.com\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"senha123\",\n  \"newPassword\": \"senha456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile (me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has name and email', () => { pm.expect(json.name).to.be.a('string'); pm.expect(json.email).to.be.a('string'); });",
                  "pm.test('Has streak fields', () => { pm.expect(json.streak).to.be.a('number'); pm.expect(json.record).to.be.a('number'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update Profile (me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name updated', () => pm.expect(pm.response.json().name).to.eql('Rodger Atualizado'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rodger Atualizado\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Victories",
      "item": [
        {
          "name": "Onboarding — Save All (PUT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('4 victories returned', () => pm.expect(json).to.have.length(4));",
                  "pm.collectionVariables.set('victoryId', json[0].id);",
                  "pm.test('Victory has id, category, goal', () => { pm.expect(json[0].id).to.be.a('string'); pm.expect(json[0].category).to.eql('FISICA'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/victories",
            "body": {
              "mode": "raw",
              "raw": "[\n  {\"category\": \"FISICA\", \"goal\": \"Malhar 30 min\", \"subtasks\": [\"Aquecimento\", \"Treino força\"]},\n  {\"category\": \"MENTAL\", \"goal\": \"Ler 20 páginas\", \"subtasks\": []},\n  {\"category\": \"ESPIRITUAL\", \"goal\": \"Meditar 10 min\", \"subtasks\": []},\n  {\"category\": \"PESSOAL\", \"goal\": \"Estudar inglês\", \"subtasks\": [\"Duolingo\"]}\n]"
            }
          }
        },
        {
          "name": "List All Victories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/victories"
          }
        },
        {
          "name": "Create Single Victory",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Victory created', () => pm.expect(pm.response.json().id).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/victories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"FISICA\",\n  \"goal\": \"Nadar 1km\",\n  \"subtasks\": [\"Aquecimento\", \"Nado livre\"]\n}"
            }
          }
        },
        {
          "name": "Update Victory",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Goal updated', () => pm.expect(pm.response.json().goal).to.eql('Malhar 45 min'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/victories/{{victoryId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"FISICA\",\n  \"goal\": \"Malhar 45 min\",\n  \"subtasks\": [\"Aquecimento\", \"Treino força\", \"Alongamento\"]\n}"
            }
          }
        },
        {
          "name": "Delete Single Victory",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/victories/{{victoryId}}"
          }
        },
        {
          "name": "Reset All Victories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/victories"
          }
        }
      ]
    },
    {
      "name": "Checkin",
      "item": [
        {
          "name": "Get Today",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has date', () => pm.expect(json.date).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
                  "pm.test('Has victories array', () => pm.expect(json.victories).to.be.an('array'));",
                  "pm.test('Has completedCount', () => pm.expect(json.completedCount).to.be.a('number'));",
                  "if (json.victories && json.victories.length > 0) {",
                  "  pm.collectionVariables.set('victoryId', json.victories[0].victoryId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/today"
          }
        },
        {
          "name": "Toggle Victory",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('completedCount changes', () => pm.expect(json.completedCount).to.be.a('number'));",
                  "pm.test('Victory toggled', () => { var v = json.victories.find(v => v.victoryId === pm.collectionVariables.get('victoryId')); pm.expect(v).to.exist; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/victory/{{victoryId}}/toggle"
          }
        },
        {
          "name": "Toggle Subtask (index 0)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Subtask toggled', () => { var v = pm.response.json().victories.find(v => v.victoryId === pm.collectionVariables.get('victoryId')); if (v && v.subtasks.length > 0) pm.expect(v.subtasks[0]).to.have.property('completed'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/victory/{{victoryId}}/subtask/0/toggle"
          }
        },
        {
          "name": "Get Streak",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has current and record', () => { pm.expect(json.current).to.be.a('number'); pm.expect(json.record).to.be.a('number'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/streak"
          }
        },
        {
          "name": "Get Weekly",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('7 days returned', () => pm.expect(json).to.have.length(7));",
                  "pm.test('Days have victories map', () => { pm.expect(json[0].victories).to.have.all.keys('fisica','mental','espiritual','pessoal'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/week"
          }
        },
        {
          "name": "Get Monthly",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has month field', () => pm.expect(json.month).to.be.a('string'));",
                  "pm.test('Has days map', () => pm.expect(json.days).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/checkin/month?m=2026-06",
              "query": [{ "key": "m", "value": "2026-06" }]
            }
          }
        },
        {
          "name": "Add Discardable Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Discardable added', () => pm.expect(json.discardable).to.have.length.above(0));",
                  "if (json.discardable && json.discardable.length > 0) {",
                  "  pm.collectionVariables.set('discardableId', json.discardable[json.discardable.length - 1].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/checkin/discardable",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"Beber 2L de água\"\n}"
            }
          }
        },
        {
          "name": "Toggle Discardable Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/discardable/{{discardableId}}/toggle"
          }
        },
        {
          "name": "Delete Discardable Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Discardable removed', () => pm.expect(pm.response.json().discardable).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/checkin/discardable/{{discardableId}}"
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "Progress Stats (6 months)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('6 months returned', () => pm.expect(json.months).to.have.length(6));",
                  "pm.test('Has current stats', () => { pm.expect(json.current.streak).to.be.a('number'); pm.expect(json.current.record).to.be.a('number'); });",
                  "pm.test('Has completion map', () => { pm.expect(json.completion).to.have.all.keys('fisica','mental','espiritual','pessoal'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/stats/monthly?months=6",
              "query": [{ "key": "months", "value": "6" }]
            }
          }
        },
        {
          "name": "Heatmap (28 days)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('28 days returned', () => pm.expect(json.days).to.have.length(28));",
                  "pm.test('Days have victories map', () => { pm.expect(json.days[0].victories).to.have.all.keys('fisica','mental','espiritual','pessoal'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/stats/heatmap"
          }
        }
      ]
    }
  ]
}
